<!-- Human-readable console appender for local development. -->
<included>
    <appender name="PLATFORM_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{correlationId:-}] [%thread] %logger{40} - %msg%n</pattern>
        </encoder>
    </appender>
</included>
