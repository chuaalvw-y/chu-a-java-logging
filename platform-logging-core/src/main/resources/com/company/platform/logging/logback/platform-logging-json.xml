<!--
    Drop-in JSON appender suitable for Docker / Kubernetes / OpenShift stdout collection.
    Splunk's HEC and the Universal Forwarder both consume this directly when configured
    with sourcetype=_json. See README "stdout vs Splunk ingestion" for details.

    Consumers include this from their own logback-spring.xml:
        <include resource="com/company/platform/logging/logback/platform-logging-json.xml"/>
        <root level="INFO"><appender-ref ref="PLATFORM_JSON"/></root>
-->
<included>
    <appender name="PLATFORM_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>@timestamp</fieldName>
                    <timeZone>UTC</timeZone>
                </timestamp>
                <version><fieldName>@version</fieldName></version>
                <logLevel><fieldName>level</fieldName></logLevel>
                <loggerName><fieldName>logger</fieldName></loggerName>
                <threadName><fieldName>thread</fieldName></threadName>
                <mdc/>
                <message/>
                <stackTrace>
                    <fieldName>stack_trace</fieldName>
                    <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                        <maxDepthPerThrowable>30</maxDepthPerThrowable>
                        <rootCauseFirst>true</rootCauseFirst>
                    </throwableConverter>
                </stackTrace>
                <pattern>
                    <pattern>
                        {
                          "service": "${app:-unknown}",
                          "env": "${env:-default}",
                          "version": "${version:-unknown}",
                          "host": "${host:-unknown}"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>
</included>
